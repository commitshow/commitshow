# Cloudflare Pages redirects.
# https://developers.cloudflare.com/pages/configuration/redirects/

# The legacy 5.6 MB animated WebP is no longer in the deploy, but old
# browser caches and Cloudflare edge still hold pages requesting it.
# Send those requests to the 12 KB static poster instead — same first
# frame, instant download, no stutter — until those caches age out.
/hero-bg.min.webp  /hero-poster.webp  301

# 2026-05-07 URL canonicalization · token leaderboard moved to primary
# /tokens surface · audit×scout 2D scatter renamed /map to match its
# visual nature. SPA Navigate routes also catch in-app navigation;
# these 301s handle external inbound traffic + search crawlers.
/leaderboard/tokens  /tokens  301
/leaderboard         /map     301

# 2026-06-09 · directory promoted from /v2 to the root domain. 301 the old
# /v2 surface to the new clean URLs so search/AEO link equity transfers.
# (/v2/admin is intentionally NOT redirected — directory admin stays there.)
/v2                      /                       301
/v2/                     /                       301
/v2/insights            /insights               301
/v2/submit              /add                    301
/v2/s/*                 /s/:splat               301
/v2/alternatives/*      /alternatives/:splat    301
